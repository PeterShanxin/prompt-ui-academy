{
  "name": "prompt-ui-academy",
  "version": "0.1.0",
  "description": "An interactive academy for learning UI terminology, motion language, and precise AI prompts.",
  "private": true,
  "license": "MIT",
  "author": "PeterShanxin",
  "homepage": "https://prompt-ui-academy.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/PeterShanxin/prompt-ui-academy.git"
  },
  "bugs": {
    "url": "https://github.com/PeterShanxin/prompt-ui-academy/issues"
  },
  "keywords": [
    "ai",
    "prompt-engineering",
    "ui-design",
    "design-education",
    "nextjs"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "install:ci": "bash scripts/install-ci.sh",
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vite",
    "build": "bash scripts/build-verified.sh",
    "build:vercel": "next build",
    "check": "npm run lint && npm run build:vercel && npm test",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run build && node --experimental-strip-types --test tests/*.test.mjs",
    "validate:artifact": "bash scripts/validate-artifact.sh",
    "lint": "bash scripts/sites-env.sh -- eslint . --ignore-pattern dist --ignore-pattern .next",
    "db:generate": "bash scripts/sites-env.sh -- drizzle-kit generate",
    "appwrite:setup": "node scripts/setup-appwrite.mjs"
  },
  "dependencies": {
    "appwrite": "26.2.0",
    "drizzle-orm": "0.45.2",
    "next": "16.2.10",
    "node-appwrite": "27.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.45.0",
    "@tailwindcss/postcss": "4.3.2",
    "@types/node": "22.20.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitejs/plugin-rsc": "0.5.27",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "react-server-dom-webpack": "19.2.7",
    "tailwindcss": "4.3.2",
    "typescript": "5.9.3",
    "vinext": "0.2.1",
    "vite": "8.1.5",
    "wrangler": "4.111.0"
  },
  "type": "module",
  "displayName": "界面话术"
}
